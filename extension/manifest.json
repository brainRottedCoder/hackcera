{
  "manifest_version": 3,
  "name": "MeetSense AI",
  "version": "2.0.0",
  "description": "Real-time meeting intelligence — auto-transcribe, extract tasks, decisions, and risks live.",

  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "sidePanel",
    "storage",
    "alarms",
    "tabCapture",
    "offscreen"
  ],

  "host_permissions": [
    "https://meet.google.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "Open MeetSense AI"
  },

  "web_accessible_resources": [
    {
      "resources": ["history.html", "history.css", "history.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
