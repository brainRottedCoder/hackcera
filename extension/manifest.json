{
  "manifest_version": 3,
  "name": "MeetSense AI",
  "version": "1.0.0",
  "description": "Real-time meeting intelligence — tasks, decisions, and risks extracted live.",

  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "sidePanel",
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "https://meet.google.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "Open MeetSense AI"
  }
}
