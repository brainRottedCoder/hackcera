# Gemini API (insights + summary)
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Deepgram API (streaming STT for tab-captured audio — fully integrated)
# Get your key at https://console.deepgram.com (free: 100 hours/month)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Server port — DO NOT set this on Railway/Render (they inject $PORT automatically)
# PORT=3001

# Set to "production" on cloud platforms
NODE_ENV=development
